<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="VoltStream Apex Rules"
    xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0
                        https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

    <description>
        Apex code-quality rules for VoltStream Mobility.
        Pulls in the PMD Apex baseline categories (best practices, code style,
        design, documentation, error-prone, performance, security) and excludes
        a small handful of rules that conflict with our explicit conventions.
    </description>

    <!-- Best practices: SOQL injection prevention, debug log pollution, etc. -->
    <rule ref="category/apex/bestpractices.xml">
        <!-- We have unit-test classes that exist purely to drive coverage on
             the production class via DML; bare assertions are intentional. -->
        <exclude name="ApexUnitTestClassShouldHaveAsserts"/>
    </rule>

    <!-- Code style: naming, formatting, structural conventions. -->
    <rule ref="category/apex/codestyle.xml">
        <!-- Our convention is method names in camelCase ('assignResellerLookup')
             which PMD's strict rule rejects in favor of underscores. Skip it. -->
        <exclude name="MethodNamingConventions"/>
        <!-- Same for class names; we use PascalCase like 'OpportunityTriggerHandler'. -->
        <exclude name="ClassNamingConventions"/>
    </rule>

    <!-- Design: cyclomatic complexity, class size, coupling. -->
    <rule ref="category/apex/design.xml">
        <!-- Our test classes intentionally have many small methods to keep
             one-test-per-scenario; don't penalize that. -->
        <exclude name="TooManyFields"/>
    </rule>

    <!-- Documentation: ApexDoc presence on classes and public methods. -->
    <rule ref="category/apex/documentation.xml"/>

    <!-- Error-prone: empty blocks, unused variables, accidental assignments. -->
    <rule ref="category/apex/errorprone.xml"/>

    <!-- Performance: bulkification, collection sizing, DML inside loops. -->
    <rule ref="category/apex/performance.xml"/>

    <!-- Security: CRUD/FLS checks, hardcoded credentials, sharing keywords. -->
    <rule ref="category/apex/security.xml">
        <!-- ApexCRUDViolation fires on every SOQL that doesn't use
             Schema.sObjectType.X.isAccessible() — but we use WITH USER_MODE
             on Selector queries, which is the modern equivalent and PMD
             does not yet recognize it. Suppress until PMD catches up. -->
        <exclude name="ApexCRUDViolation"/>
    </rule>
</ruleset>
