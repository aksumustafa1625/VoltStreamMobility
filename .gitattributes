# Normalize line endings on commit; check out as LF on every platform.
* text=auto eol=lf

# Salesforce metadata — always LF.
*.cls            text eol=lf
*.cls-meta.xml   text eol=lf
*.trigger        text eol=lf
*.trigger-meta.xml text eol=lf
*.apex           text eol=lf
*.xml            text eol=lf
*.json           text eol=lf
*.yml            text eol=lf
*.yaml           text eol=lf
*.md             text eol=lf

# Binaries — leave untouched.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.zip  binary
